VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# Development (uses Vite proxy)
VITE_API_BASE_URL=/api/youtube

# Production (direct YouTube API URL)
# VITE_API_BASE_URL=https://www.googleapis.com/youtube/v3

VITE_USE_MOCK=false

# Mock error simulation (development only)
# VITE_MOCK_ERROR=false
# VITE_MOCK_ERROR_CODE=500
# VITE_MOCK_ERROR_RATE=0.3
